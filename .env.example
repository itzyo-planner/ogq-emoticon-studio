# Emoticon Studio 환경변수 예시
# 실제 사용 시 이 파일을 .env.local 로 복사하고 값을 채워주세요.
#
# 모든 API 키는 클라이언트 측 입력 폼(Step 1)에서도 받을 수 있으므로
# 이 파일은 필수가 아닙니다. 비워 두어도 앱은 정상 동작합니다.

# Google Gemini API key (https://aistudio.google.com/apikey)
GEMINI_API_KEY=

# OpenAI API key (https://platform.openai.com/api-keys)
OPENAI_API_KEY=

# Stability AI API key (https://platform.stability.ai/account/keys)
STABILITY_API_KEY=

# Codex(ChatGPT Plus/Pro) 사용 시 키는 필요 없습니다.
# 대신 터미널에서 1회 OAuth 로그인이 필요합니다:
#   npx @openai/codex login
